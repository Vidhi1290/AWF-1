# ---- n8n Code node sandbox ----
# Required so the "Extract DOCX Text" Code node can `require('mammoth')`.
NODE_FUNCTION_ALLOW_EXTERNAL=mammoth
# Required so Code nodes can use built-in Node modules (fs, crypto).
NODE_FUNCTION_ALLOW_BUILTIN=fs,crypto

# ---- Ollama (local LLM, no API key required) ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
# Alternative, slower but more accurate: gpt-oss:20b

# ---- NocoDB ----
# Base URL of your self-hosted NocoDB instance, used only for reference/README;
# the n8n NocoDB node uses its own credential (API token), not this URL.
NOCODB_URL=http://localhost:8080
NOCODB_BASE_ID=replace_with_your_base_id
NOCODB_TABLE_ID=replace_with_your_candidates_table_id
NOCODB_ERROR_LOG_TABLE_ID=replace_with_your_error_log_table_id

# ---- Job description used for matching ----
# Path as seen from inside the n8n container/process.
JD_FILE_PATH=/data/job_description.md

# ---- Shortlisting thresholds (Step 7) ----
MATCH_SCORE_SHORTLIST_THRESHOLD=80
MATCH_SCORE_REVIEW_THRESHOLD=60

# ---- Recruiter alerting (error handler workflow) ----
RECRUITER_ALERT_EMAIL=vidhiwaghela99@gmail.com

# ---- Credentials created inside the n8n UI (not env vars, listed for reference) ----
# - Gmail OAuth2 - Recruitment Inbox   (Gmail Trigger + Gmail send nodes)
# - NocoDB API Token                    (all NocoDB nodes)
# - Google Calendar OAuth2              (Create Interview Event node)
